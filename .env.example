# TanStack Start app server environment
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# For Docker Compose with the sibling spotify-lyrics-api container, keep the internal hostname below.
# For external/public deployments, use https://spotify-lyrics-api.louismollick.com/
SPOTIFY_LYRICS_API_URL=http://spotify-lyrics-api:8080

# Optional: path to a mounted Netscape-format youtube cookies.txt file.
# When set, both yt-dlp and youtubei.js use it.
YTDLP_COOKIES_PATH=

# Optional: explicit binary paths (app can auto-download yt-dlp if absent)
YTDLP_BINARY_PATH=
FFMPEG_PATH=

# spotify-lyrics-api container env
SP_DC=your_sp_dc_cookie
