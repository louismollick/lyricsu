# TanStack Start app server environment
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_LYRICS_API_URL=http://spotify-lyrics-api:8080

# Optional: pass cookies to improve YTMusic API results
YTMUSIC_COOKIES=

# Optional: explicit binary paths (app can auto-download yt-dlp if absent)
YTDLP_BINARY_PATH=
FFMPEG_PATH=

# spotify-lyrics-api container env
SP_DC=your_sp_dc_cookie
